# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ERP Database (read-only access)
# SQLite example:
ERP_DATABASE_URL=sqlite:///D:/Projects/Umiya/Umiya_Dashboard/backend/db.sqlite3
# PostgreSQL example:
# ERP_DATABASE_URL=postgresql://postgres:password@localhost:5432/umiya_dashboard

# API Security
AI_SERVICE_API_KEY=umiya-ai-dev-key-change-in-production

# ChromaDB
CHROMA_DB_PATH=./data/chroma_db

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chat History
CHAT_HISTORY_DB_PATH=./data/chat_history.db

# Service
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=info
